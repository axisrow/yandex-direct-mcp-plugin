# Single source of truth for runtime dependency pins.
#
# Both bootstrap channels source this file:
#   - hooks/setup.sh                       (Claude Code SessionStart)
#   - plugins/yandex-direct/run-server.sh  (Codex bundle cold start, via
#                                           plugins/yandex-direct/scripts/runtime-pins.env)
#
# The Codex copy under plugins/yandex-direct/scripts/ must stay byte-identical;
# tests/test_pins_consistency.py guards this.
#
# Editing this file by hand is fine, but prefer:
#   scripts/update-pins.sh MCP_VER DIRECT_CLI_VER   — for the two runtime deps
#   scripts/update-version.sh PLUGIN_VER            — for PLUGIN_VERSION
#
# Stamp file in $CLAUDE_PLUGIN_DATA:
#   .installed-${PLUGIN_VERSION}-${MCP_VERSION}-${DIRECT_CLI_VERSION}
# Any of the three changing invalidates the stamp and re-runs bootstrap once.
PLUGIN_VERSION=0.3.3
MCP_VERSION=1.23.3
DIRECT_CLI_VERSION=0.4.3
